#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
ROOT_DIR="$(cd -- "${SCRIPT_DIR}/.." && pwd)"

source "${ROOT_DIR}/lib/common.sh"
source "${ROOT_DIR}/lib/apps.sh"

CLEANUP_WORKDIR=""
CLEANUP_INSTANCE_NAME=""
CLEANUP_ENABLED="false"
CLEANUP_INSTANCE_CREATED="false"
CLEANUP_DRY_RUN="false"

cleanup_create_context() {
  if [[ -n "${CLEANUP_WORKDIR}" ]]; then
    rm -rf "${CLEANUP_WORKDIR}"
  fi

  if [[ "${CLEANUP_ENABLED}" == "true" && "${CLEANUP_DRY_RUN}" != "true" && "${CLEANUP_INSTANCE_CREATED}" == "true" && -n "${CLEANUP_INSTANCE_NAME}" ]]; then
    log "Cleaning up failed instance ${CLEANUP_INSTANCE_NAME}"
    incus_delete_instance "${CLEANUP_INSTANCE_NAME}"
  fi
}

main() {
  local cmd="${1:-}"
  case "${cmd}" in
    list-supported)
      shift || true
      cmd_list_supported "$@"
      ;;
    list-profiled)
      shift || true
      cmd_list_supported "$@"
      ;;
    show)
      shift || true
      cmd_show "$@"
      ;;
    search)
      shift || true
      cmd_search "$@"
      ;;
    create)
      shift || true
      cmd_create "$@"
      ;;
    smoke-test)
      shift || true
      cmd_smoke_test "$@"
      ;;
    addon)
      shift || true
      cmd_addon "$@"
      ;;
    ""|-h|--help|help)
      usage
      ;;
    *)
      die "Unknown command: ${cmd}"
      ;;
  esac
}

usage() {
  cat <<'EOF'
Usage:
  incus-app list-supported
  incus-app list-profiled
  incus-app show <app> [--ref <git-ref>]
  incus-app search <query>
  incus-app create <app> [--name <instance>] [--ref <git-ref>] [--dry-run] [--cleanup-on-failure] [--prompt-mode <interactive|profile|empty>]
  incus-app smoke-test <app> [--name <instance>] [--ref <git-ref>] [--dry-run] [--cleanup-on-failure] [--prompt-mode <interactive|profile|empty>]
  incus-app addon install <addon> --target <instance> [--ref <git-ref>] [--dry-run] [--prompt-mode <interactive|empty>]
  incus-app addon update <addon> --target <instance> [--ref <git-ref>] [--dry-run] [--prompt-mode <interactive|empty>]

Commands:
  list-supported    Show apps with launcher automation profiles
  list-profiled     Alias for list-supported
  show              Display upstream defaults and launcher notes
  search            Search optional PocketBase metadata by name, slug, or description
  create            Create an Incus container and run the upstream installer
  smoke-test        Create an app, run a basic instance/service check
  addon             Run an upstream addon script inside an existing container
EOF
}

cmd_list_supported() {
  assert_no_args "$@"
  list_profiled_apps
}

cmd_show() {
  local app="${1:-}"
  [[ -n "${app}" ]] || die "show requires an app name"
  shift || true

  local ref="main"
  local show_dry_run="false"
  local show_name=""
  local show_cleanup_on_failure="false"
  local show_prompt_mode=""
  parse_common_args ref show_dry_run show_name show_cleanup_on_failure show_prompt_mode "$@"

  local workdir
  workdir="$(mktemp -d)"
  local metadata_file="${workdir}/metadata.json"

  metadata_clear
  if metadata_fetch_record "${app}" "${metadata_file}" 2>/dev/null; then
    metadata_parse_record "${metadata_file}" || true
  fi

  if [[ "${PB_FOUND}" == "yes" ]]; then
    cat <<EOF
App: ${PB_NAME:-${app}}
Slug: ${PB_SLUG:-${app}}
Ref: ${ref}
Metadata source: PocketBase
Script mode: ${PB_SOURCE_TYPE}
Script path: ${PB_SCRIPT_PATH}
Source repo: $(metadata_repo_name)
Description: ${PB_DESCRIPTION:-n/a}
Categories: ${PB_CATEGORIES:-n/a}
Website: ${PB_WEBSITE:-n/a}
Documentation: ${PB_DOCUMENTATION:-n/a}
Config path: ${PB_CONFIG_PATH:-n/a}
Interface port: ${PB_PORT:-n/a}
Updateable: ${PB_UPDATEABLE}
Privileged: ${PB_PRIVILEGED}
Is development: ${PB_IS_DEV}
Is disabled: ${PB_IS_DISABLED}
Is deleted: ${PB_IS_DELETED}
EOF
  else
    cat <<EOF
App: ${app}
Ref: ${ref}
Metadata source: script parsing only
EOF
  fi

  if [[ "${PB_SOURCE_TYPE:-lxc}" == "lxc" || "${PB_FOUND}" != "yes" ]]; then
    fetch_upstream_bundle "${app}" "${ref}" "${workdir}"
    parse_ct_metadata "${workdir}/ct.sh"
    detect_install_interactivity "${workdir}/install.sh"

    cat <<EOF
CPU: ${META_CPU}
RAM MiB: ${META_RAM}
Disk GiB: ${META_DISK}
OS: ${META_OS}
Version: ${META_VERSION}
Unprivileged: ${META_UNPRIVILEGED}
Needs TUN: ${META_TUN}
Needs Nesting: ${META_NESTING}
Needs FUSE: ${META_FUSE}
Needs GPU: ${META_GPU}
Interactive mode: $(app_interactivity "${app}")
Automation: $(app_automation_summary "${app}")
EOF

    if [[ "${INTERACTIVE_DETECTED}" == "yes" ]]; then
      printf 'Interactive hints:\n%s\n' "${INTERACTIVE_MATCHES}"
    fi
  else
    case "${PB_SOURCE_TYPE}" in
      addon)
        cat <<EOF
Launcher path: use \`incus-app addon install ${PB_SLUG} --target <instance>\`
EOF
        ;;
      pve)
        cat <<EOF
Launcher path: not supported for execution; this is a Proxmox host tool
EOF
        ;;
      vm)
        cat <<EOF
Launcher path: not supported for execution; VM creation is not implemented
EOF
        ;;
    esac
  fi

  rm -rf "${workdir}"
}

cmd_search() {
  local query="${1:-}"
  [[ -n "${query}" ]] || die "search requires a query"
  shift || true
  assert_no_args "$@"

  metadata_supported || die "search requires jq"

  local tmp_file
  tmp_file="$(mktemp)"
  metadata_fetch_all_records "${tmp_file}"

  jq -r --arg q "${query}" '
    select(
      ((.name // "") | ascii_downcase | contains($q | ascii_downcase)) or
      ((.slug // "") | ascii_downcase | contains($q | ascii_downcase)) or
      ((.description // "") | ascii_downcase | contains($q | ascii_downcase))
    )
    | [
        (.name // ""),
        (.slug // ""),
        (.expand.type.type // .type // ""),
        (if (.is_dev // false) then "dev" else "prod" end),
        (.description // "")
      ] | @tsv
  ' "${tmp_file}" | while IFS=$'\t' read -r name slug source_type repo_state description; do
    printf '%s\t%s\t%s\t%s\t%s\n' "${name}" "${slug}" "${source_type}" "${repo_state}" "${description}"
  done

  rm -f "${tmp_file}"
}

cmd_create() {
  local app="${1:-}"
  [[ -n "${app}" ]] || die "create requires an app name"
  shift || true

  local ref="main"
  local dry_run="false"
  local name=""
  local cleanup_on_failure="false"
  local prompt_mode=""
  parse_common_args ref dry_run name cleanup_on_failure prompt_mode "$@"

  run_create_flow "${app}" "${ref}" "${name}" "${dry_run}" "${cleanup_on_failure}" "false" "${prompt_mode}"
}

cmd_smoke_test() {
  local app="${1:-}"
  [[ -n "${app}" ]] || die "smoke-test requires an app name"
  shift || true

  local ref="main"
  local dry_run="false"
  local name=""
  local cleanup_on_failure="false"
  local prompt_mode=""
  parse_common_args ref dry_run name cleanup_on_failure prompt_mode "$@"

  run_create_flow "${app}" "${ref}" "${name}" "${dry_run}" "${cleanup_on_failure}" "true" "${prompt_mode}"
}

cmd_addon() {
  local addon_action="${1:-}"
  [[ -n "${addon_action}" ]] || die "addon requires an action: install or update"
  shift || true

  case "${addon_action}" in
    install|update) ;;
    *)
      die "Unsupported addon action: ${addon_action}"
      ;;
  esac

  local addon_name="${1:-}"
  [[ -n "${addon_name}" ]] || die "addon ${addon_action} requires an addon name"
  shift || true

  local ref="main"
  local dry_run="false"
  local target=""
  local prompt_mode="interactive"
  parse_addon_args ref dry_run target prompt_mode "$@"

  run_addon_flow "${addon_name}" "${addon_action}" "${target}" "${ref}" "${dry_run}" "${prompt_mode}"
}

run_create_flow() {
  local app="$1"
  local ref="$2"
  local name="$3"
  local dry_run="$4"
  local cleanup_on_failure="$5"
  local run_smoke_test="$6"
  local prompt_mode="$7"

  if [[ -z "${name}" ]]; then
    name="${app}"
  fi

  if [[ "${dry_run}" != "true" ]]; then
    require_bin curl
    require_bin incus
  else
    require_bin curl
  fi

  if [[ -z "${prompt_mode}" ]]; then
    if has_automation_profile "${app}"; then
      prompt_mode="profile"
    else
      prompt_mode="empty"
    fi
  fi

  case "${prompt_mode}" in
    interactive|profile|empty) ;;
    *)
      die "Unsupported prompt mode: ${prompt_mode}"
      ;;
  esac

  if [[ "${prompt_mode}" == "interactive" && "${dry_run}" != "true" && ! -t 0 ]]; then
    die "Interactive prompt mode requires a TTY"
  fi

  local workdir
  workdir="$(mktemp -d)"
  local instance_created="false"

  CLEANUP_WORKDIR="${workdir}"
  CLEANUP_INSTANCE_NAME="${name}"
  CLEANUP_ENABLED="${cleanup_on_failure}"
  CLEANUP_INSTANCE_CREATED="false"
  CLEANUP_DRY_RUN="${dry_run}"

  trap 'cleanup_create_context' EXIT

  local metadata_file="${workdir}/metadata.json"
  metadata_clear
  if metadata_fetch_record "${app}" "${metadata_file}" 2>/dev/null; then
    metadata_parse_record "${metadata_file}" || true
  fi

  if [[ "${PB_FOUND}" == "yes" && "${PB_SOURCE_TYPE}" != "lxc" ]]; then
    case "${PB_SOURCE_TYPE}" in
      addon)
        die "${app} is an addon script; use: incus-app addon install ${PB_SLUG} --target <instance>"
        ;;
      pve)
        die "${app} is a Proxmox host tool and cannot be created as an Incus app container"
        ;;
      vm)
        die "${app} is a VM script and VM creation is not implemented"
        ;;
      *)
        die "${app} is not an LXC app script"
        ;;
    esac
  fi

  fetch_upstream_bundle "${app}" "${ref}" "${workdir}"
  parse_ct_metadata "${workdir}/ct.sh"
  detect_install_interactivity "${workdir}/install.sh"
  render_runtime_files "${app}" "${name}" "${workdir}"

  local image
  image="$(resolve_image "${META_OS}" "${META_VERSION}")"

  log "Creating ${app} as Incus instance ${name} from ${image}"
  log "Prompt mode: ${prompt_mode}"

  if [[ "${INTERACTIVE_DETECTED}" == "yes" && "${prompt_mode}" == "empty" ]] && ! has_automation_profile "${app}"; then
    log "Detected upstream interactive prompts for ${app}, but no launcher automation profile exists yet."
  fi

  incus_prepare_instance "${name}" "${image}" "${dry_run}"
  instance_created="true"
  CLEANUP_INSTANCE_CREATED="true"
  incus_apply_limits "${name}" "${dry_run}"
  incus_apply_features "${name}" "${dry_run}"
  incus_start_instance "${name}" "${dry_run}"
  incus_push_runtime "${name}" "${workdir}" "${dry_run}"
  incus_bootstrap_guest "${name}" "${dry_run}"
  incus_run_installer "${name}" "${dry_run}" "${prompt_mode}"

  if [[ "${run_smoke_test}" == "true" ]]; then
    local check_cmd
    check_cmd="$(app_smoke_check_command "${app}")"
    log "Running smoke check for ${app}"
    incus_smoke_check "${name}" "${check_cmd}" "${dry_run}"
  fi

  if [[ "${dry_run}" == "true" ]]; then
    log "Dry run complete"
  else
    if [[ "${run_smoke_test}" == "true" ]]; then
      log "Smoke test complete"
    else
      log "Creation complete"
    fi
  fi

  trap - EXIT
  CLEANUP_WORKDIR=""
  CLEANUP_INSTANCE_NAME=""
  CLEANUP_ENABLED="false"
  CLEANUP_INSTANCE_CREATED="false"
  CLEANUP_DRY_RUN="false"
  rm -rf "${workdir}"
}

run_addon_flow() {
  local addon_name="$1"
  local addon_action="$2"
  local target="$3"
  local ref="$4"
  local dry_run="$5"
  local prompt_mode="$6"

  [[ -n "${target}" ]] || die "addon ${addon_action} requires --target <instance>"

  if [[ "${dry_run}" != "true" ]]; then
    require_bin curl
    require_bin incus
  else
    require_bin curl
  fi

  case "${prompt_mode}" in
    interactive|empty) ;;
    *)
      die "Unsupported prompt mode for addons: ${prompt_mode}"
      ;;
  esac

  if [[ "${prompt_mode}" == "interactive" && "${dry_run}" != "true" && ! -t 0 ]]; then
    die "Interactive prompt mode requires a TTY"
  fi

  if [[ "${dry_run}" != "true" ]] && ! incus_instance_exists "${target}"; then
    die "Target instance not found: ${target}"
  fi

  local workdir
  workdir="$(mktemp -d)"
  local metadata_file="${workdir}/metadata.json"

  metadata_clear
  if metadata_fetch_record "${addon_name}" "${metadata_file}" 2>/dev/null; then
    metadata_parse_record "${metadata_file}" || true
  fi

  fetch_upstream_addon "${addon_name}" "${ref}" "${workdir}"

  log "Running addon ${addon_name} (${addon_action}) in existing instance ${target}"
  log "Prompt mode: ${prompt_mode}"

  incus_bootstrap_existing_guest "${target}" "${dry_run}"
  incus_push_addon_script "${target}" "${workdir}" "${dry_run}"
  incus_run_addon_script "${target}" "${dry_run}" "${prompt_mode}" "${addon_action}"
  rm -rf "${workdir}"
}

parse_common_args() {
  local -n _ref="$1"
  local -n _dry_run="$2"
  local -n _name="$3"
  local -n _cleanup_on_failure="$4"
  local -n _prompt_mode="$5"
  shift 5 || true

  while (($#)); do
    case "$1" in
      --ref)
        _ref="${2:?missing value for --ref}"
        shift 2
        ;;
      --dry-run)
        _dry_run="true"
        shift
        ;;
      --name)
        _name="${2:?missing value for --name}"
        shift 2
        ;;
      --cleanup-on-failure)
        _cleanup_on_failure="true"
        shift
        ;;
      --prompt-mode)
        _prompt_mode="${2:?missing value for --prompt-mode}"
        shift 2
        ;;
      *)
        die "Unknown argument: $1"
        ;;
    esac
  done
}

parse_addon_args() {
  local -n _ref="$1"
  local -n _dry_run="$2"
  local -n _target="$3"
  local -n _prompt_mode="$4"
  shift 4 || true

  while (($#)); do
    case "$1" in
      --ref)
        _ref="${2:?missing value for --ref}"
        shift 2
        ;;
      --dry-run)
        _dry_run="true"
        shift
        ;;
      --target)
        _target="${2:?missing value for --target}"
        shift 2
        ;;
      --prompt-mode)
        _prompt_mode="${2:?missing value for --prompt-mode}"
        shift 2
        ;;
      *)
        die "Unknown argument: $1"
        ;;
    esac
  done
}

assert_no_args() {
  (($# == 0)) || die "This command takes no arguments"
}

main "$@"
